syntax = "v1"

type (
	LogEventsReq {
		Logs []LogEventItem `json:"logs"`
	}
	LogEventItem {
		Level     string `json:"level"`
		BucketID  string `json:"bucketId"`
		Data      string `json:"data"`
		Timestamp int64  `json:"timestamp,optional"`
	}
	LogEventsRes {}
)

@server (
	group: track_public
)
service platform {
	@doc "记录客户端日志"
	@handler LogEvents
	post /api/platform/track_public/v1/log (LogEventsReq) returns (LogEventsRes)
}
