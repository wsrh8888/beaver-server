syntax = "v1"

// ==================== 应用密钥管理 ====================

type (
	ResetAppSecretReq {
		AppID string `json:"appId"`
	}
	
	ResetAppSecretRes {
		AppID     string `json:"appId"`
		AppSecret string `json:"appSecret"`
		Message   string `json:"message"` // 提示信息：请妥善保管新密钥
	}
)

@server (
	group: app
)
service open {
	@doc "重置应用密钥"
	@handler ResetAppSecret
	post /portal/open/v1/app/secret/reset (ResetAppSecretReq) returns (ResetAppSecretRes)
}
