type (
	LoginReq {
		Username string `json:"username"` // 手机号或邮箱
		Password string `json:"password"`
	}
	LoginRes {
		Token    string `json:"token"`
		UserID   string `json:"userId"`
		NickName string `json:"nickName"` // 用户昵称
		ExpireAt int64  `json:"expireAt"`
	}
)

@server (group: auth)
service open {
	@handler Login
	post /portal/open/v1/auth/login (LoginReq) returns (LoginRes)
}
